{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "custom",
  "keybinds": {
    "leader": "ctrl+o",

    "editor_open": "<leader>e",
    "model_list": "<leader>m",
    "command_list": "<leader>p",
    "agent_list": "<leader>a",

    "session_new": "<leader>n",
    "session_list": "<leader>k",
    "session_timeline": "<leader>g",
    "session_compact": "<leader>c",
    "session_interrupt": "escape,ctrl+c",

    "input_newline": "ctrl+return,alt+return",
    "input_submit": "return",

    "input_move_up": "ctrl+k",
    "input_move_down": "ctrl+j",
    "input_move_left": "ctrl+h",
    "input_move_right": "ctrl+l",

    "input_delete_to_line_end": "none",

    "history_previous": "ctrl+p",
    "history_next": "ctrl+n",

    "messages_copy": "<leader>y",
    "messages_undo": "<leader>u",
    "messages_redo": "<leader>r",

    "terminal_suspend": "ctrl+z"
  }
}
