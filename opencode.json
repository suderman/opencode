{
  "$schema": "https://opencode.ai/config.json",
  "autoshare": false,
  "autoupdate": true,
  "lsp": true,
  "model": "minimax-coding-plan/MiniMax-M3",
  "small_model": "minimax-coding-plan/MiniMax-M2.7",
  "default_agent": "mini",
  "agent": {
    "build": {
      "model": "openai/gpt-5.6-sol",
      "permission": {
        "task": "deny"
      }
    },
    "plan": {
      "model": "openai/gpt-5.6-sol",
      "permission": {
        "task": "deny"
      }
    }
  },
  "permission": {
    "MiniMax_understand_image": "deny",
    "external_directory": {
      "/nix/store/**": "allow",
      "/tmp/**": "allow"
    },
    "read": {
      "*": "allow",
      "*.env": "ask",
      "*.env.*": "ask",
      "*.env.example": "allow",
      "/nix/store/**": "allow",
      "/tmp/**": "allow"
    },
    "edit": {
      "/nix/store/**": "deny",
      "/tmp/**": "allow"
    },
    "bash": {
      "*": "allow",
      "git push*": "ask",
      "*nixos-rebuild*": "deny"
    }
  },
  "plugin": [
    "opencode-ntfy.sh",
    "@simonwjackson/opencode-direnv",
    "@tarquinen/opencode-dcp@latest"
  ],
  "provider": {
    "minimax": {
      "options": {
        "apiKey": "{env:MINIMAX_API_KEY}"
      }
    },
    "openai": {
      "options": {
        "apiKey": "{env:CODEX_LB_API_KEY}",
        "baseURL": "https://codex-lb.kit/v1"
      },
      "models": {
        "gpt-5.6-sol": {
          "name": "GPT-5.6 Sol",
          "reasoning": true,
          "options": {
            "reasoningEffort": "medium",
            "reasoningSummary": "auto"
          }
        },
        "gpt-5.6-terra": {
          "name": "GPT-5.6 Terra",
          "reasoning": true,
          "options": {
            "reasoningEffort": "medium",
            "reasoningSummary": "auto"
          }
        },
        "gpt-5.5": {
          "name": "GPT-5.5",
          "reasoning": true,
          "options": {
            "reasoningEffort": "medium",
            "reasoningSummary": "auto"
          }
        },
        "gpt-5.4": {
          "name": "GPT-5.4",
          "reasoning": true,
          "options": {
            "reasoningEffort": "medium",
            "reasoningSummary": "auto"
          }
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini",
          "reasoning": true,
          "options": {
            "reasoningEffort": "medium",
            "reasoningSummary": "auto",
            "textVerbosity": "low"
          }
        }
      }
    },
    "opencode": {
      "options": {
        "apiKey": "{env:ZEN_API_KEY}"
      }
    },
    "openrouter": {
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      }
    }
  },
  "mcp": {
    "MiniMax": {
      "enabled": true,
      "type": "local",
      "command": ["uvx", "minimax-coding-plan-mcp"],
      "environment": {
        "MINIMAX_API_KEY": "{env:MINIMAX_API_KEY}",
        "MINIMAX_API_HOST": "https://api.minimax.io"
      }
    },
    "chrome-devtools": {
      "enabled": true,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--browser-url=http://127.0.0.1:9222",
        "--no-usage-statistics"
      ]
    },
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "gh_grep": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "figma": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.figma.com/mcp"
    }
  }
}
